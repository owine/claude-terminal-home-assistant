{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "commitMessageAction": "update",
  "timezone": "America/Chicago",
  "schedule": [
    "on Monday"
  ],
  "automergeSchedule": [
    "at any time"
  ],
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Home Assistant base images - disable digest pinning (tracked via build.yaml)",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/home-assistant/amd64-base",
        "ghcr.io/home-assistant/aarch64-base"
      ],
      "pinDigests": false
    },
    {
      "description": "Home Assistant base images - disable Dockerfile manager (source of truth is build.yaml)",
      "matchManagers": [
        "dockerfile"
      ],
      "matchPackageNames": [
        "ghcr.io/home-assistant/amd64-base"
      ],
      "enabled": false
    },
    {
      "description": "Group all non-major updates into a single weekly PR",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin"
      ],
      "groupName": "all non-major dependencies",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Major updates - separate PRs for review",
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "dependencies",
        "major-update"
      ],
      "automerge": false
    },
    {
      "description": "Auto-merge Claude Code patch updates from stable channel",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "custom.claude-code"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Use deps: commit type for release-please compatibility (deps is a releasable unit)",
      "semanticCommitType": "deps",
      "semanticCommitScope": "",
      "matchUpdateTypes": ["minor", "patch", "digest", "major", "pin", "lockFileMaintenance"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash"
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "customManagers": [
    {
      "description": "Update Claude Code version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=custom\\.claude-code\\s+ARG\\s+CLAUDE_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "custom.claude-code",
      "depNameTemplate": "claude-code"
    },
    {
      "description": "Update Dockerfile ARG versions with renovate comments",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\s+ARG [A-Z_]+_VERSION=(?<currentValue>\\S+)"
      ]
    },
    {
      "description": "Update version pins in shell scripts with renovate comments",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/scripts//"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\s+(?:local )?\\w+=\\\"(?<currentValue>[^\\\"]+)\\\""
      ]
    },
    {
      "description": "Update git commit SHA pins in Dockerfile ARGs",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=git-refs depName=(?<depName>\\S+) packageName=(?<packageName>\\S+) branch=(?<currentValue>\\S+)\\s+ARG [A-Z_]+=(?<currentDigest>[0-9a-f]{40})"
      ],
      "datasourceTemplate": "git-refs"
    },
    {
      "description": "Update build_from base images in build.yaml",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/build\\.yaml$/"
      ],
      "matchStrings": [
        "(?:aarch64|amd64):\\s*(?<depName>ghcr\\.io/[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Update pinned Alpine apk packages via Repology. IMPORTANT: bump alpine version in depNameTemplate when base image changes (e.g. alpine_3_23 → alpine_3_24)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "\\s\\s(?<package>[a-z0-9][a-z0-9-_]+)=(?<currentValue>[a-z0-9-_.]+)\\s+"
      ],
      "versioningTemplate": "loose",
      "datasourceTemplate": "repology",
      "depNameTemplate": "alpine_3_23/{{package}}"
    }
  ],
  "customDatasources": {
    "claude-code": {
      "defaultRegistryUrlTemplate": "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/stable",
      "format": "plain"
    }
  }
}
