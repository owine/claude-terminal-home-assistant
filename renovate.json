{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>owine/renovate-config",
    "github>owine/renovate-config:automerge",
    "github>owine/renovate-config:python",
    "github>owine/renovate-config:docker"
  ],
  "packageRules": [
    {
      "description": "Home Assistant base images — disable digest pinning (tracked via build.yaml as the source of truth)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/home-assistant/amd64-base",
        "ghcr.io/home-assistant/aarch64-base"
      ],
      "pinDigests": false
    },
    {
      "description": "HA amd64-base — disable the Dockerfile manager; build.yaml is the source of truth",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/home-assistant/amd64-base"],
      "enabled": false
    },
    {
      "description": "Auto-merge Claude Code patch updates from the stable channel",
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["custom.claude-code"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "description": "Update Claude Code version in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=custom\\.claude-code\\s+ARG\\s+CLAUDE_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "custom.claude-code",
      "depNameTemplate": "claude-code"
    },
    {
      "description": "Update Dockerfile ARG versions with renovate comments",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\s+ARG [A-Z_]+_VERSION=(?<currentValue>\\S+)"
      ]
    },
    {
      "description": "Update version pins in shell scripts with renovate comments",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/scripts//"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\s+(?:local )?\\w+=\\\"(?<currentValue>[^\\\"]+)\\\""
      ]
    },
    {
      "description": "Update git commit SHA pins in Dockerfile ARGs",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=git-refs depName=(?<depName>\\S+) packageName=(?<packageName>\\S+) branch=(?<currentValue>\\S+)\\s+ARG [A-Z_]+=(?<currentDigest>[0-9a-f]{40})"
      ],
      "datasourceTemplate": "git-refs"
    },
    {
      "description": "Update build_from base images in build.yaml",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/build\\.yaml$/"
      ],
      "matchStrings": [
        "(?:aarch64|amd64):\\s*(?<depName>ghcr\\.io/[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Update pinned Alpine apk packages via Repology. IMPORTANT: bump alpine version in depNameTemplate when the base image changes (e.g. alpine_3_23 -> alpine_3_24)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^claude-terminal/Dockerfile$/"
      ],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "\\s\\s(?<package>[a-z0-9][a-z0-9-_]+)=(?<currentValue>[a-z0-9-_.]+)\\s+"
      ],
      "versioningTemplate": "loose",
      "datasourceTemplate": "repology",
      "depNameTemplate": "alpine_3_23/{{package}}"
    }
  ],
  "customDatasources": {
    "claude-code": {
      "defaultRegistryUrlTemplate": "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/stable",
      "format": "plain"
    }
  }
}
