#!/bin/bash

# User-friendly command for installing packages persistently
# Usage: persist-install python git vim

PERSIST_ROOT="/data/packages"
PERSIST_BIN="$PERSIST_ROOT/bin"
PERSIST_PYTHON="$PERSIST_ROOT/python"

# Echo the Python minor version (e.g. "3.14") the system interpreter reports.
system_python_minor() {
    python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])' 2>/dev/null
}

# Echo the Python minor version recorded in a venv's pyvenv.cfg (empty if absent).
# Matches both "version = 3.14.6" and "version_info = 3.14.6.final.0".
venv_python_minor() {
    sed -n 's/^version[_a-z]*[[:space:]]*=[[:space:]]*\([0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' \
        "$1/pyvenv.cfg" 2>/dev/null | head -n1
}

# Decide whether the persistent venv must be (re)created.
# A venv binds to a specific Python minor version: bin/python symlinks to the
# system interpreter and packages live in lib/pythonX.Y/site-packages. When the
# base image bumps Python (e.g. 3.12 -> 3.14), the old site-packages (and pip)
# are orphaned, so the venv's pip fails with "No module named 'pip'". Detect a
# missing, corrupt, or version-mismatched venv so callers can rebuild it.
venv_needs_recreate() {
    local venv_dir="$1"

    [ -d "$venv_dir" ] || return 0
    [ -f "$venv_dir/pyvenv.cfg" ] || return 0

    local current
    current=$(system_python_minor) || return 0
    [ -n "$current" ] || return 0

    [ "$(venv_python_minor "$venv_dir")" = "$current" ] && return 1
    return 0
}

show_help() {
    cat << EOF
🔧 Persistent Package Installer

Install packages that survive container restarts!

USAGE:
    persist-install <package1> [package2] [...]
    persist-install --python <package1> [package2] [...]
    persist-install --list
    persist-install --help

EXAMPLES:
    persist-install git vim htop          # Install system packages
    persist-install --python requests pandas  # Install Python packages
    persist-install --list                # Show installed packages

NOTES:
    • Packages are installed to: /data/packages (persistent storage)
    • Survives container restarts and reboots
    • System packages copied from Alpine APK
    • Python packages installed to virtual environment

QUICK START:
    1. persist-install python3 py3-pip    # Install Python (first time)
    2. Reboot and enjoy! Packages will still be there!

EOF
}

list_packages() {
    echo "=== 📦 Persistent Packages ==="
    echo ""
    echo "📁 Location: $PERSIST_ROOT"
    echo ""

    echo "🔧 System Binaries ($PERSIST_BIN):"
    if [ -d "$PERSIST_BIN" ] && [ -n "$(ls -A "$PERSIST_BIN" 2>/dev/null)" ]; then
        for bin in "$PERSIST_BIN"/*; do
            echo "  • $(basename "$bin")"
        done
    else
        echo "  (none installed)"
    fi
    echo ""

    echo "🐍 Python Packages ($PERSIST_PYTHON/venv):"
    if [ -f "$PERSIST_PYTHON/venv/bin/pip" ]; then
        source "$PERSIST_PYTHON/venv/bin/activate"
        pip list --format=columns | tail -n +3 | sed 's/^/  • /'
    else
        echo "  (virtual environment not created)"
        echo "  Run: persist-install python3 py3-pip"
    fi
    echo ""

    echo "💾 Total size:"
    du -sh "$PERSIST_ROOT" 2>/dev/null || echo "  0B"
}

install_system_packages() {
    local packages=("$@")

    echo "📦 Installing system packages: ${packages[*]}"
    echo ""

    # Install via APK first
    echo "⏳ Installing via APK..."
    if ! apk add --no-cache "${packages[@]}"; then
        echo "❌ Failed to install packages"
        exit 1
    fi

    # Copy to persistent storage
    echo "💾 Copying to persistent storage..."
    mkdir -p "$PERSIST_BIN" "$PERSIST_ROOT/lib"

    for pkg in "${packages[@]}"; do
        echo "  Processing: $pkg"

        # Get list of files installed by package
        apk info -L "$pkg" 2>/dev/null | while read -r file; do
            # Copy executables
            if [[ "$file" == /usr/bin/* ]] || [[ "$file" == /usr/sbin/* ]] || [[ "$file" == /bin/* ]]; then
                if [ -f "$file" ] && [ -x "$file" ]; then
                    cp -a "$file" "$PERSIST_BIN/" 2>/dev/null && echo "    ✓ $(basename "$file")"
                fi
            fi

            # Copy shared libraries
            if [[ "$file" == /usr/lib/* ]] && [[ "$file" == *.so* ]]; then
                if [ -f "$file" ]; then
                    cp -a "$file" "$PERSIST_ROOT/lib/" 2>/dev/null
                fi
            fi
        done
    done

    echo ""
    echo "✅ System packages installed and persisted!"
    echo "💡 These packages will survive container restarts"
}

install_python_packages() {
    local packages=("$@")

    echo "🐍 Installing Python packages: ${packages[*]}"
    echo ""

    # Ensure system Python exists before building/repairing the venv.
    if ! command -v python3 &>/dev/null; then
        echo "❌ Python not installed. Installing..."
        install_system_packages python3 py3-pip
    fi

    # (Re)create the venv when missing, corrupt, or built against a different
    # Python version. The last case happens after an Alpine base-image upgrade
    # bumps the interpreter (e.g. 3.12 -> 3.14), orphaning the old pip and
    # breaking it with "No module named 'pip'".
    if venv_needs_recreate "$PERSIST_PYTHON/venv"; then
        if [ -d "$PERSIST_PYTHON/venv" ]; then
            local had
            had=$(venv_python_minor "$PERSIST_PYTHON/venv")
            echo "♻️  Rebuilding virtual environment (venv Python ${had:-unknown} != system Python $(system_python_minor))..."
            rm -rf "$PERSIST_PYTHON/venv"
        else
            echo "⚠️  Python virtual environment not found"
            echo "📥 Creating virtual environment..."
        fi

        mkdir -p "$PERSIST_PYTHON"
        python3 -m venv "$PERSIST_PYTHON/venv"
        echo "✅ Virtual environment ready"
        echo ""
    fi

    # Activate and install
    source "$PERSIST_PYTHON/venv/bin/activate"

    echo "⏳ Installing packages..."
    pip install --upgrade pip -q
    pip install "${packages[@]}"

    echo ""
    echo "✅ Python packages installed!"
    echo "💡 Use 'source $PERSIST_PYTHON/venv/bin/activate' to activate venv"
}

# Main execution
main() {
    # Check if running in the app
    if [ ! -d "/data" ]; then
        echo "❌ Error: /data directory not found"
        echo "This script must run inside the Claude Terminal app"
        exit 1
    fi

    case "${1:-}" in
        --help|-h|help)
            show_help
            ;;
        --list|-l|list)
            list_packages
            ;;
        --python|-p|python)
            shift
            if [ $# -eq 0 ]; then
                echo "❌ Error: No packages specified"
                echo "Usage: persist-install --python <package1> [package2] ..."
                exit 1
            fi
            install_python_packages "$@"
            ;;
        "")
            show_help
            ;;
        *)
            install_system_packages "$@"
            ;;
    esac
}

# Only run main when executed directly, not when sourced (e.g. by tests).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
